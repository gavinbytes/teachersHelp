generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth Models ──────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  preferences   Json      @default("{}")

  accounts Account[]
  sessions Session[]
  classes  Class[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── App Models ──────────────────────────────────────────────

model Class {
  id        String   @id @default(cuid())
  name      String
  subject   String
  color     String   @default("#3b82f6")
  room      String?
  startDate DateTime?
  endDate   DateTime?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedules         ClassSchedule[]
  students          Student[]
  lessons           Lesson[]
  categories        AssignmentCategory[]
  assignments       Assignment[]
  unitPlans         UnitPlan[]
  classSessions     ClassSession[]
  taskTemplates     SessionTaskTemplate[]

  @@index([userId])
}

model ClassSchedule {
  id        String @id @default(cuid())
  classId   String
  dayOfWeek Int    // 0=Sunday, 1=Monday, ..., 6=Saturday
  startTime String // "08:30"
  endTime   String // "09:20"

  class         Class          @relation(fields: [classId], references: [id], onDelete: Cascade)
  lessons       Lesson[]
  classSessions ClassSession[]

  @@index([classId])
}

model Student {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String?
  classId   String
  createdAt DateTime @default(now())

  class  Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  grades Grade[]

  @@index([classId])
}

// ─── Lesson Planning ─────────────────────────────────────────

enum LessonStatus {
  DRAFT
  PLANNED
  COMPLETED
}

model Lesson {
  id             String       @id @default(cuid())
  title          String
  content        String?      @db.Text
  date           DateTime
  status         LessonStatus @default(DRAFT)
  classId        String
  scheduleId     String?
  classSessionId String?      @unique
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  class        Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  schedule     ClassSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  classSession ClassSession? @relation(fields: [classSessionId], references: [id], onDelete: SetNull)

  @@index([classId])
  @@index([date])
}

// ─── Grading ─────────────────────────────────────────────────

enum AssignmentType {
  HOMEWORK
  QUIZ
  TEST
  PROJECT
  PARTICIPATION
  OTHER
}

model AssignmentCategory {
  id      String @id @default(cuid())
  name    String
  weight  Float  @default(0) // percentage weight, all should sum to 100
  classId String

  class       Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  assignments Assignment[]

  @@index([classId])
}

model Assignment {
  id         String         @id @default(cuid())
  name       String
  type       AssignmentType @default(HOMEWORK)
  points     Float          @default(100)
  dueDate    DateTime?
  classId    String
  categoryId String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  class    Class               @relation(fields: [classId], references: [id], onDelete: Cascade)
  category AssignmentCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  grades   Grade[]

  @@index([classId])
  @@index([categoryId])
}

enum GradeStatus {
  GRADED
  MISSING
  EXCUSED
  LATE
}

model Grade {
  id           String      @id @default(cuid())
  score        Float?
  status       GradeStatus @default(GRADED)
  studentId    String
  assignmentId String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@unique([studentId, assignmentId])
  @@index([assignmentId])
}

// ─── Class Sessions ─────────────────────────────────────────

model ClassSession {
  id         String   @id @default(cuid())
  date       DateTime
  classId    String
  scheduleId String
  notes      String?  @db.Text

  class    Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  schedule ClassSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  lesson   Lesson?
  tasks    SessionTask[]

  @@unique([scheduleId, date])
  @@index([classId])
  @@index([date])
}

model SessionTask {
  id             String  @id @default(cuid())
  title          String
  completed      Boolean @default(false)
  sortOrder      Int     @default(0)
  classSessionId String
  templateId     String?

  classSession ClassSession         @relation(fields: [classSessionId], references: [id], onDelete: Cascade)
  template     SessionTaskTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([classSessionId])
}

model SessionTaskTemplate {
  id        String  @id @default(cuid())
  title     String
  sortOrder Int     @default(0)
  classId   String
  isDefault Boolean @default(true)

  class Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  tasks SessionTask[]

  @@index([classId])
}

// (Task model removed — replaced by SessionTask)

// ─── Unit Plans ──────────────────────────────────────────────

enum SubUnitStatus {
  PLANNED
  TAUGHT
  SKIPPED
}

model UnitPlan {
  id        String   @id @default(cuid())
  classId   String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  class Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
  units Unit[]

  @@index([classId])
}

model Unit {
  id         String   @id @default(cuid())
  unitPlanId String
  name       String
  weekNumber Int
  sortOrder  Int
  createdAt  DateTime @default(now())

  unitPlan UnitPlan  @relation(fields: [unitPlanId], references: [id], onDelete: Cascade)
  subUnits SubUnit[]

  @@index([unitPlanId])
}

model SubUnit {
  id        String        @id @default(cuid())
  unitId    String
  name      String
  sortOrder Int
  status    SubUnitStatus @default(PLANNED)

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId])
}
